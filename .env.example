DATABASE_URL=postgresql://udd_app:***@localhost:5432/udd_prod
BETTER_AUTH_SECRET=replace-me-with-32-plus-char-secret
BETTER_AUTH_URL=http://localhost:3000

# Supabase legacy data layer (still required until full Drizzle migration completes)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App encryption key (AES-256-GCM for user secrets / credential storage)
UDD_SECRET_KEY=replace-me-with-32-char-random-base64

# AI provider default (openai | anthropic)
UDD_AI_PROVIDER=openai

# Vercel AI Gateway API key (optional — falls back to stored BYOK provider keys if missing)
AI_GATEWAY_API_KEY=
