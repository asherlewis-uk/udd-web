DATABASE_URL=postgresql://udd_app:***@localhost:5432/udd_prod
BETTER_AUTH_SECRET=replace-me-with-32-plus-char-secret
BETTER_AUTH_URL=http://localhost:3000

# App encryption key (AES-256-GCM for user secrets / credential storage)
UDD_SECRET_KEY=replace-me-with-32-char-random-base64

# AI provider default (openai | anthropic | ollama)
UDD_AI_PROVIDER=openai

# Optional Ollama/self-hosted OpenAI-compatible provider settings.
# When UDD_DEFAULT_AI_BASE_URL is set, the env-default provider resolves to ollama.
UDD_DEFAULT_AI_BASE_URL=
UDD_DEFAULT_AI_MODEL=qwen2.5-coder
UDD_DEFAULT_AI_API_KEY=
